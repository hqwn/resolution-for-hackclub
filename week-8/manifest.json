{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "Bob"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": false,
      "messages_tab_read_only_enabled": true
    },
    "bot_user": {
      "display_name": "Bob",
      "always_online": true
    },
    "shortcuts": [
      {
        "name": "Run sample shortcut",
        "type": "global",
        "callback_id": "sample_shortcut_id",
        "description": "Runs a sample shortcut"
      }
    ],
    "slash_commands": [
      {
        "command": "/make-task",
        "description": "Creates a new task for the channel",
        "usage_hint": "Enter a task description",
        "should_escape": false
      },
      {
        "command": "/all-tasks",
        "description": "Lists all tasks for the channel",
        "usage_hint": "No additional input needed",
        "should_escape": false
      },
      {
        "command": "/delete-task",
        "description": "Deletes a task by its ID",
        "usage_hint": "Enter the task ID, do /all-tasks to find the ID",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "channels:read",
        "chat:write",
        "commands",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_home_opened",
        "message.channels",
        "member_joined_channel"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
